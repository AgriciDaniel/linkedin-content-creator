# ========================================
# LinkedIn OAuth Configuration
# ========================================
# Get these values from https://www.linkedin.com/developers/apps

# Your LinkedIn App Client Secret (REQUIRED for OAuth)
# Go to: LinkedIn Dev Portal → Your App → Auth tab → Copy "Primary Client Secret"
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Your LinkedIn App Client ID (REQUIRED for OAuth)
# Go to: LinkedIn Dev Portal → Your App → Auth tab → Copy "Client ID"
LINKEDIN_CLIENT_ID=your_client_id_here

# Optional: Proxy server port (default: 3002)
SERVER_PORT=3002

# Optional: Frontend redirect URI (default: http://localhost:3001)
REDIRECT_URI=http://localhost:3001

# ========================================
# AI Services Configuration
# ========================================

# Gemini API Key (REQUIRED for AI content generation)
# Get from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firecrawl API Key (REQUIRED for web research, topic suggestions, competitive analysis)
# Get from: https://www.firecrawl.dev/ (Sign up for free tier)
VITE_FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ========================================
# Frontend Configuration
# ========================================

# Proxy Server URL (for frontend to backend communication)
VITE_PROXY_SERVER_URL=http://localhost:3002

# ========================================
# Optional Services
# ========================================

# DataForSEO API (for advanced keyword research - optional)
# DATAFORSEO_LOGIN=your_dataforseo_login
# DATAFORSEO_PASSWORD=your_dataforseo_password

# Cloudflare R2 Storage (for image hosting - optional)
# R2_ACCOUNT_ID=your_r2_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET_NAME=your_bucket_name
